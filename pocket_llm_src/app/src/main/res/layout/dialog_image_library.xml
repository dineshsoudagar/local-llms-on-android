<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_panel"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/imageLibraryTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/images_section_title"
        android:textColor="?attr/colorAssistantText"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/imageLibrarySubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/image_library_hint"
        android:textColor="?attr/colorStatusText"
        android:textSize="13sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:layout_marginTop="14dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/imageLibraryRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/imageLibraryEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="@string/no_saved_images"
            android:textColor="?attr/colorStatusText"
            android:textSize="15sp"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/imageLibraryCloseButton"
            style="@style/DialogSecondaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:text="@string/close" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/imageLibraryDeleteButton"
            style="@style/DialogPrimaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:enabled="false"
            android:text="@string/delete_selected_images"
            app:backgroundTint="?attr/colorStopFill"
            app:rippleColor="?attr/colorStopStroke"
            app:strokeColor="?attr/colorStopStroke" />
    </LinearLayout>

</LinearLayout>
