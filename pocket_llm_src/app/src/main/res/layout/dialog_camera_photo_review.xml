<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dialog_panel"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingTop="18dp"
    android:paddingBottom="14dp">

    <TextView
        android:id="@+id/cameraPhotoReviewTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/camera_photo_review_title"
        android:textColor="?attr/colorAssistantText"
        android:textSize="20sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/cameraPhotoReviewImage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:background="@color/black"
        android:contentDescription="@string/camera_photo_preview"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/cameraPhotoReviewStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/camera_photo_review_status"
        android:textColor="?attr/colorStatusText"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cameraPhotoRetakeButton"
            style="@style/DialogSecondaryButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/camera_retake_photo" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cameraPhotoCropButton"
            style="@style/DialogSecondaryButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:contentDescription="@string/camera_crop_action"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:minWidth="48dp"
            android:paddingHorizontal="0dp"
            android:text=""
            app:icon="@drawable/ic_crop_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cameraPhotoUseButton"
            style="@style/DialogPrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:text="@string/camera_use_photo" />
    </LinearLayout>
</LinearLayout>
