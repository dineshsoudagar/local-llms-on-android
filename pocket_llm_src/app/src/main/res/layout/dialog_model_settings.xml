<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_panel"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/modelSettingsDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/model_settings_title"
        android:textColor="?attr/colorAssistantText"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/modelSettingsModelName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="?attr/colorStatusText"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/modelInstructionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/model_instruction_label"
        android:textColor="?attr/colorAssistantText"
        android:textSize="16sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/modelInstructionInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/rounded_edittext"
        android:gravity="top|start"
        android:inputType="textMultiLine|textCapSentences"
        android:maxLines="12"
        android:minLines="7"
        android:padding="12dp"
        android:scrollbars="vertical"
        android:textColor="?attr/colorInputText"
        android:textColorHint="?attr/colorInputHint"
        android:textSize="15sp" />

    <LinearLayout
        android:id="@+id/modelSettingsActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/modelSettingsCancelButton"
            style="@style/DialogSecondaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:text="@android:string/cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/modelSettingsSaveButton"
            style="@style/DialogPrimaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/save" />
    </LinearLayout>
</LinearLayout>
