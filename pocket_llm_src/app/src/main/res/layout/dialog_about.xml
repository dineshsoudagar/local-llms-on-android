<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_panel"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/aboutAppName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/toolbar_app_title"
        android:textColor="?attr/colorAssistantText"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/aboutVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="?attr/colorStatusText"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/aboutGithubLink"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:autoLink="web"
        android:linksClickable="true"
        android:text="@string/about_github_link"
        android:textColor="?attr/colorAssistantText"
        android:textSize="15sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/aboutOkButton"
        style="@style/DialogPrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@android:string/ok" />
</LinearLayout>
