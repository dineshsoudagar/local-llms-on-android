<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_panel"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/savedChatsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/previous_chats"
        android:textColor="?attr/colorAssistantText"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/savedChatsSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/saved_chats_subtitle"
        android:textColor="?attr/colorStatusText"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/savedChatsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="4dp" />

</LinearLayout>
