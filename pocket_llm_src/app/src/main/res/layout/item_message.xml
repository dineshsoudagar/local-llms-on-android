<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/messageContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:paddingHorizontal="4dp"
    android:paddingVertical="5dp">

    <LinearLayout
        android:id="@+id/preResponseStatusContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/preResponseStatusView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_chip"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp"
            android:textColor="?attr/colorStatusText"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/thoughtContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/thoughtHeaderView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_chip"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp"
            android:textColor="?attr/colorStatusText"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/thoughtView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="4dp"
            android:paddingHorizontal="12dp"
            android:textColor="?attr/colorStatusText"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/messageBubbleFrame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/messageImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:background="@drawable/bg_bubble_user"
            android:clipToOutline="true"
            android:contentDescription="@string/chat_image_attachment"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <TextView
            android:id="@+id/messageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bubble_bot"
            android:lineSpacingExtra="4dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:textColor="?attr/colorAssistantText"
            android:textIsSelectable="true"
            android:textSize="16sp" />

        <ImageButton
            android:id="@+id/copyResponseButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|top"
            android:layout_marginEnd="4dp"
            android:layout_marginTop="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/copy_response"
            android:padding="5dp"
            android:src="@drawable/ic_copy_20"
            android:tint="?attr/colorStatusText"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
