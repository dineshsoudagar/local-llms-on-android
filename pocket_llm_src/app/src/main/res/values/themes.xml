<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.local_llm" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/frame_layout_background</item>
        <item name="colorPrimaryVariant">@color/app_background</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnBackground">@color/assistant_text</item>
        <item name="colorSurface">@color/frame_layout_background</item>
        <item name="colorOnSurface">@color/assistant_text</item>
        <item name="android:windowBackground">?attr/colorAppBackground</item>
        <item name="colorAppBackground">@color/app_background</item>
        <item name="colorFrameBackground">@color/frame_layout_background</item>
        <item name="colorUserBubble">@color/user_bubble</item>
        <item name="colorAssistantBubble">@color/bot_bubble</item>
        <item name="colorUserText">@color/user_text</item>
        <item name="colorAssistantText">@color/assistant_text</item>
        <item name="colorInputBackground">@color/app_background</item>
        <item name="colorInputText">@color/assistant_text</item>
        <item name="colorInputHint">@color/input_hint</item>
        <item name="colorStatusText">@color/status_text</item>
